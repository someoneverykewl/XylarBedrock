<Page x:Class="XylarBedrock.Pages.Preview.Installation.EditInstallationVersionSelectScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XylarBedrock.Pages.Preview"
        d:DataContext="{d:DesignInstance Type=viewModels:EditInstallationVersionSelectViewModel}"
        xmlns:p="clr-namespace:XylarBedrock.Properties"
        xmlns:controls="clr-namespace:XylarBedrock.Pages.Preview.Installation.Components"
        xmlns:classes="clr-namespace:XylarBedrock.Classes"
        xmlns:viewModels="clr-namespace:XylarBedrock.ViewModels"
        xmlns:converters="clr-namespace:JemExtensions.WPF.Converters;assembly=JemExtensions"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="800"
        Loaded="Page_Loaded"
        Width="Auto" Height="Auto">
    <Page.Resources>
        <CollectionViewSource x:Key="Versions" Source="{Binding Versions, Source={x:Static viewModels:MainDataModel.Default}}" Filter="CollectionViewSource_Filter"/>
    </Page.Resources>
    <Grid Margin="0" Background="{DynamicResource Background.Dialog}" Style="{DynamicResource DisabledStyle}" IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="75"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Margin="18,18,18,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{DynamicResource GeneralSubtitles_Versions}"
                       Foreground="{DynamicResource PrimaryText.Foreground}"
                       FontWeight="Bold"
                       FontSize="18"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <TextBlock Grid.Row="1"
                       Margin="0,6,0,0"
                       Text="Showing supported Minecraft for Windows versions ready to install."
                       Foreground="{DynamicResource SecondaryText.Foreground}"
                       FontSize="12"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Grid>
        <Grid Grid.Row="1" Margin="18,0,18,12" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource PrimaryText.Foreground}" Text="{DynamicResource GeneralSubtitles_Search}" Margin="0,0,0,6" FontWeight="Bold" FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                <ContentControl Style="{DynamicResource TextboxLikeFrame}" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Image Width="18" Margin="8,0,6,0" Height="18" Source="{DynamicResource SearchIcon}"/>
                        <TextBox TextChanged="SearchBox_TextChanged" Grid.Column="1" Style="{DynamicResource BlankTextBox}" x:Name="SearchBox" Tag="{DynamicResource InstallationVersionSelect_SearchBar_Content}" Text="{Binding Path=FilterString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </ContentControl>
            </StackPanel>
        </Grid>
        <Border Grid.Row="2"
                Margin="18,0,18,12"
                Background="{DynamicResource Background.Primary}"
                BorderBrush="{DynamicResource Seperator.Background}"
                BorderThickness="1"
                CornerRadius="12">
            <ListView x:Name="VersionsList"
                      ItemsSource="{Binding Source={StaticResource Versions}, IsAsync=True}"
                      SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                      SelectionChanged="VersionsList_SelectionChanged"
                      MouseDoubleClick="VersionsList_MouseDoubleClick"
                      PreviewKeyDown="VersionsList_PreviewKeyDown"
                      SelectionMode="Single"
                      HorizontalContentAlignment="Stretch"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="10">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type classes:MCVersion}">
                        <controls:Component_VersionSelectItem DataContext="{Binding }"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <Separator Grid.Row="3" Margin="0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="4" Height="45" Margin="15,0">
            <Button x:Name="CancelButton" Click="CancelButton_Click" Content="{DynamicResource GeneralText_Cancel}" Style="{DynamicResource DialogButton}"></Button>
            <Button x:Name="SelectButton" Click="CreateButton_Click" Content="{DynamicResource GeneralText_Select}" Style="{DynamicResource DialogButton_Green}"></Button>
        </StackPanel>
    </Grid>
</Page>

