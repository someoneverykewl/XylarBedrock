<Page x:Class="XylarBedrock.Pages.Play.Home.PlayScreenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:properties="clr-namespace:XylarBedrock.Properties"
    xmlns:classes="clr-namespace:XylarBedrock.Classes"
    xmlns:viewModels="clr-namespace:XylarBedrock.ViewModels"
    xmlns:config="clr-namespace:XylarBedrock.ViewModels"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:controls="clr-namespace:XylarBedrock.Pages.Play.Home.Components"
    DataContext="{x:Static viewModels:MainDataModel.Default}"
    mc:Ignorable="d"
    d:DesignHeight="608" d:DesignWidth="828"
    Title="PlayScreenPage">
    <Page.Resources>
        <sys:Double x:Key="MaxLogoHeight">100</sys:Double>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Loaded="Grid_Loaded">
            <Grid.RowDefinitions>
                <RowDefinition Height="18"></RowDefinition>
                <RowDefinition MinHeight="66"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.ColumnSpan="3" Grid.RowSpan="3">
                <Grid.Background>
                    <ImageBrush Stretch="UniformToFill" RenderOptions.BitmapScalingMode="Fant" x:Name="ImageBrush"/>
                </Grid.Background>
                <Grid.Effect>
                    <BlurEffect Radius="1"></BlurEffect>
                </Grid.Effect>
            </Grid>

            <Image x:Name="BugrockOfTheWeekLogo" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1" MaxHeight="{DynamicResource MaxLogoHeight}" Source="/XylarBedrock;component/resources/images/logo/OfTheWeek.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" >
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1" ScaleY="1"/>
                        <SkewTransform CenterY="0.5" CenterX="0.5"/>
                        <RotateTransform CenterY="0.5" CenterX="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" BeginTime="00:00:00">
                                    <LinearDoubleKeyFrame KeyTime="00:00:0" Value="0" />
                                    <LinearDoubleKeyFrame KeyTime="00:00:1.16" Value="0" />
                                    <LinearDoubleKeyFrame KeyTime="00:00:1.55" Value="1" />
                                </DoubleAnimationUsingKeyFrames>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                    <SplineThicknessKeyFrame KeyTime="00:00:0" Value="0,-40,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:1.16" Value="0,-40,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:1.25" Value="0,28,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:1.35" Value="0,18,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:1.40" Value="0,24,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:1.55" Value="0,18,0,0" />
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <Image x:Name="BugrockLogo"  VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1" MaxHeight="{DynamicResource MaxLogoHeight}" Source="/XylarBedrock;component/resources/images/logo/BugrockEdition.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" >
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1" ScaleY="1"/>
                        <SkewTransform CenterY="0.5" CenterX="0.5"/>
                        <RotateTransform CenterY="0.5" CenterX="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                    <SplineThicknessKeyFrame KeyTime="00:00:0" Value="0,-55,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.15" Value="0,28,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.25" Value="0,18,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.30" Value="0,24,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.35" Value="0,18,0,0" />
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>
            <Image x:Name="BedrockLogo" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1" MaxHeight="{DynamicResource MaxLogoHeight}" Source="/XylarBedrock;component/resources/images/logo/BedrockEdition.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" >
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5" ScaleX="1" ScaleY="1"/>
                        <SkewTransform CenterY="0.5" CenterX="0.5"/>
                        <RotateTransform CenterY="0.5" CenterX="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                                    <SplineThicknessKeyFrame KeyTime="00:00:0" Value="0,-55,5,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.15" Value="0,28,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.25" Value="0,18,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.30" Value="0,24,0,0" />
                                    <SplineThicknessKeyFrame KeyTime="00:00:0.35" Value="0,18,0,0" />
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
            </Image>
        </Grid>
        <Grid x:Name="PlayScreenBorder" Grid.Row="1" x:FieldModifier="public" VerticalAlignment="Bottom" Background="#FF262626">
            <TextBlock Style="{DynamicResource HeaderTextblock}" Text="{DynamicResource MainWindow_Disclaimer}" HorizontalAlignment="Right" Panel.ZIndex="0" VerticalAlignment="Center" Padding="0,0,5,0" Margin="0,0,0,0"/>
            <Button x:Name="MainPlayButton" Click="MainPlayButton_Click" HorizontalAlignment="Center" Margin="0,-8,0,0" VerticalAlignment="Top" Width="360" Height="56" Padding="0" Style="{DynamicResource BigGreenButton}">
                <TextBlock x:Name="PlayButtonText" Style="{DynamicResource BigGreenButton_Text}" Text="PLAY"/>
            </Button>
            <StackPanel x:Name="LaunchStatusPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,48,0,0" Visibility="Collapsed">
                <TextBlock x:Name="LaunchStatusText" Text="Opening the game..." Foreground="White" FontSize="12" FontFamily="Minecraft Seven v2" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <ProgressBar x:Name="LaunchStatusBar" Width="240" Height="6" IsIndeterminate="True" Foreground="#FF57C7FF" Background="#55222222"/>
            </StackPanel>
            <ComboBox x:Name="PlayVersionsList"
                      HorizontalAlignment="Left"
                      Margin="4,4,0,4"
                      VerticalAlignment="Top"
                      Width="290"
                      Height="50"
                      Foreground="White"
                      SelectionChanged="PlayVersionsList_SelectionChanged"
                      IsEnabled="{Binding ProgressBarState.AllowEditing, Mode=OneWay}"
                      Style="{DynamicResource InstallationSelectorComboBoxStyle}"
                      Padding="-1,7,5,3">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type classes:MCVersion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Image RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="{Binding VersionListIconPath}"
                                   HorizontalAlignment="Left"
                                   Width="32"
                                   Height="32"
                                   Margin="5,1,0,0">
                                <Image.OpacityMask>
                                    <ImageBrush ImageSource="{Binding VersionListIconPath}"/>
                                </Image.OpacityMask>
                            </Image>
                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource PrimaryText.Foreground}" FontWeight="SemiBold" Padding="12,0,0,0" Text="{Binding DisplayName}"/>
                            <TextBlock Grid.Column="1" FontSize="10" Foreground="{DynamicResource SecondaryText.Foreground}" Padding="12,20,0,0" FontWeight="Normal" Text="{Binding InstallationSize}"/>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>
    </Grid>

</Page>

