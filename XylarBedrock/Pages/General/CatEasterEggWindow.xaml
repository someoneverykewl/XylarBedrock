<Window x:Class="XylarBedrock.Pages.General.CatEasterEggWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="160"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseDown="Window_MouseDown">
    <Grid Background="#66000000">
        <Border x:Name="PopupCard"
                Width="250"
                Height="112"
                CornerRadius="12"
                Background="#F2171717"
                BorderBrush="#FF5D5D5D"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Color="#000000"
                                  Opacity="0.65"/>
            </Border.Effect>
            <Grid>
                <Button Width="24"
                        Height="24"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Content="x"
                        Foreground="#D9FFFFFF"
                        Background="#333333"
                        BorderBrush="#666666"
                        Click="CloseButton_Click"/>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="/XylarBedrock;component/resources/images/icons/cateasteregg.png"
                           Width="42"
                           Height="42"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                    <TextBlock Text="meow!^_~"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
