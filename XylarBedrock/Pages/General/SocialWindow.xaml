<Window x:Class="XylarBedrock.Pages.General.SocialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="650"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SocialTabButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Foreground" Value="#BFFFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SocialActionButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="#FF101010"/>
            <Setter Property="Background" Value="#FF8AF05A"/>
            <Setter Property="BorderBrush" Value="#FFE8FF74"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFA5FF6F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerActionButton" BasedOn="{StaticResource SocialActionButton}" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#FFFFEEEE"/>
            <Setter Property="Background" Value="#FF5B2027"/>
            <Setter Property="BorderBrush" Value="#FFA64A58"/>
        </Style>

        <DataTemplate x:Key="FriendTemplate">
            <Border Background="#A51F2028"
                    BorderBrush="#293C404C"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="72"/>
                    </Grid.ColumnDefinitions>
                    <Grid Width="38"
                          Height="38"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                        <Ellipse Fill="{Binding AccentBrush}"/>
                        <TextBlock Text="{Binding Initial}"
                                   Foreground="#FF121212"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="12"
                                 Height="12"
                                 Fill="{Binding StatusBrush}"
                                 Stroke="#15161C"
                                 StrokeThickness="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"/>
                    </Grid>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#96FFFFFF"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="Block"
                            Tag="{Binding Name}"
                            Style="{StaticResource DangerActionButton}"
                            Height="30"
                            Click="BlockPersonButton_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RequestTemplate">
            <Border Background="#A51F2028"
                    BorderBrush="#293C404C"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding DirectionLabel}"
                                   Foreground="#94FFFFFF"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Cancel"
                            Tag="{Binding Name}"
                            Width="70"
                            Height="30"
                            Style="{StaticResource DangerActionButton}"
                            Click="CancelRequestButton_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BlockedTemplate">
            <Border Background="#7A341C22"
                    BorderBrush="#805A3139"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="78"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding}"
                               Foreground="#FFEDEDED"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Unblock"
                            Tag="{Binding}"
                            Height="30"
                            Style="{StaticResource SocialActionButton}"
                            Click="UnblockButton_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GroupTemplate">
            <Border Background="#A51F2028"
                    BorderBrush="#293C404C"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding VisibilityLabel}"
                                   Foreground="#94FFFFFF"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            CornerRadius="9"
                            Background="#263EFF8A"
                            BorderBrush="#5549FF92"
                            BorderThickness="1"
                            Padding="9,5"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding MemberCountLabel}"
                                   Foreground="#CFFFFFFF"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="22"
            BorderBrush="#3846505D"
            BorderThickness="1"
            Background="#F20D0E14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40"
                              ShadowDepth="0"
                              Color="#000000"
                              Opacity="0.78"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF11131B" Offset="0"/>
                    <GradientStop Color="#FF0C0D12" Offset="0.45"/>
                    <GradientStop Color="#FF17100E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="260"
                     Height="260"
                     Fill="#2442F56B"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-110,-130,0,0"/>
            <Ellipse Width="220"
                     Height="220"
                     Fill="#1A57BFFF"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-118,-92"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="74"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="18,14,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Width="42"
                          Height="42"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                        <Ellipse Fill="#FFB7FBAE"/>
                        <TextBlock Text="{Binding CurrentInitial}"
                                   Foreground="#FF111111"
                                   FontWeight="Black"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="12"
                                 Height="12"
                                 Fill="#FF42E85D"
                                 Stroke="#FF11131B"
                                 StrokeThickness="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"/>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/XylarBedrock;component/resources/images/icons/friends_icon.png"
                                   Width="24"
                                   Height="24"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,1,8,0"/>
                            <TextBlock Text="Social"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Black"
                                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                        </StackPanel>
                        <TextBlock x:Name="ProfileIdText"
                                   Text="Real friend data only. No fake users."
                                   Foreground="#8FFFFFFF"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="x"
                            Style="{StaticResource IconButton}"
                            FontSize="15"
                            FontWeight="Bold"
                            Click="CloseButton_Click"/>
                </Grid>

                <Border Grid.Row="1"
                        Margin="18,2,18,12"
                        Height="52"
                        CornerRadius="18"
                        Background="#AE202129"
                        BorderBrush="#1FFFFFFF"
                        BorderThickness="1">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="FriendsTabButton"
                                Content="Friends"
                                Style="{StaticResource SocialTabButton}"
                                Click="FriendsTabButton_Click"/>
                        <Button x:Name="RequestsTabButton"
                                Grid.Column="1"
                                Content="Requests"
                                Style="{StaticResource SocialTabButton}"
                                Click="RequestsTabButton_Click"/>
                        <Button x:Name="GroupsTabButton"
                                Grid.Column="2"
                                Content="Groups"
                                Style="{StaticResource SocialTabButton}"
                                Click="GroupsTabButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Height="46"
                        Margin="18,0,18,14"
                        CornerRadius="23"
                        Background="#AE1B1C23"
                        BorderBrush="#CFFFFFFF"
                        BorderThickness="2"
                        Padding="16,0">
                    <Grid>
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="Search friends..."
                                   Foreground="#78FFFFFF"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <TextBox x:Name="SearchTextBox"
                                 TextChanged="SearchTextBox_TextChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="3"
                              Margin="18,0,12,0"
                              VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel x:Name="FriendsPanel">
                            <DockPanel Margin="0,0,6,10">
                                <TextBlock x:Name="FriendsSectionTitle"
                                           Text="Friends"
                                           Foreground="#D8FFFFFF"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                                <TextBlock x:Name="FriendCountText"
                                           DockPanel.Dock="Right"
                                           Foreground="#8FFFFFFF"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>

                            <Border x:Name="EmptyFriendsPanel"
                                    CornerRadius="18"
                                    Background="#9A1A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="18"
                                    Margin="0,10,6,0">
                                <StackPanel>
                                    <TextBlock Text="No friends yet"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Black"/>
                                    <TextBlock Text="Open Requests and send a real friend request. This list starts empty on purpose."
                                               Foreground="#A8FFFFFF"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                    <Button Content="Send a request"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            Margin="0,16,0,0"
                                            Style="{StaticResource SocialActionButton}"
                                            Click="RequestsTabButton_Click"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Friends}"
                                          ItemTemplate="{StaticResource FriendTemplate}"/>
                        </StackPanel>

                        <StackPanel x:Name="RequestsPanel"
                                    Visibility="Collapsed">
                            <TextBlock Text="Add friend"
                                       Foreground="#D8FFFFFF"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <Border CornerRadius="16"
                                    Background="#9A1A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,6,16">
                                <StackPanel>
                                    <TextBlock Text="Enter their Xylar profile name"
                                               Foreground="#A8FFFFFF"
                                               FontSize="12"/>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="106"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="FriendNameTextBox"
                                                 Height="38"
                                                 Foreground="White"
                                                 Background="#FF202129"
                                                 BorderBrush="#404B5766"
                                                 Padding="10,0"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="Send"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource SocialActionButton}"
                                                Click="AddFriendButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <DockPanel Margin="0,0,6,10">
                                <TextBlock Text="Pending requests"
                                           Foreground="#D8FFFFFF"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                                <TextBlock x:Name="RequestCountText"
                                           DockPanel.Dock="Right"
                                           Foreground="#8FFFFFFF"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Border x:Name="EmptyRequestsPanel"
                                    CornerRadius="16"
                                    Background="#661A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,6,12">
                                <TextBlock Text="No pending requests."
                                           Foreground="#A8FFFFFF"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <ItemsControl ItemsSource="{Binding OutgoingRequests}"
                                          ItemTemplate="{StaticResource RequestTemplate}"/>

                            <DockPanel Margin="0,14,6,10">
                                <TextBlock Text="Blocked"
                                           Foreground="#D8FFFFFF"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                                <TextBlock x:Name="BlockedCountText"
                                           DockPanel.Dock="Right"
                                           Foreground="#8FFFFFFF"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Border x:Name="EmptyBlockedPanel"
                                    CornerRadius="16"
                                    Background="#661A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,6,12">
                                <TextBlock Text="No blocked users."
                                           Foreground="#A8FFFFFF"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <ItemsControl ItemsSource="{Binding BlockedUsers}"
                                          ItemTemplate="{StaticResource BlockedTemplate}"/>
                        </StackPanel>

                        <StackPanel x:Name="GroupsPanel"
                                    Visibility="Collapsed">
                            <TextBlock Text="Create group"
                                       Foreground="#D8FFFFFF"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Margin="0,0,0,10"/>
                            <Border CornerRadius="16"
                                    Background="#9A1A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,6,16">
                                <StackPanel>
                                    <TextBox x:Name="GroupNameTextBox"
                                             Height="38"
                                             Foreground="White"
                                             Background="#FF202129"
                                             BorderBrush="#404B5766"
                                             Padding="10,0"
                                             VerticalContentAlignment="Center"/>
                                    <CheckBox x:Name="PublicGroupCheckBox"
                                              Content="Make this group public"
                                              Foreground="#D8FFFFFF"
                                              Margin="0,12,0,12"/>
                                    <Button Content="Create Group"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource SocialActionButton}"
                                            Click="CreateGroupButton_Click"/>
                                </StackPanel>
                            </Border>

                            <DockPanel Margin="0,0,6,10">
                                <TextBlock Text="Groups"
                                           Foreground="#D8FFFFFF"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                                <TextBlock x:Name="GroupCountText"
                                           DockPanel.Dock="Right"
                                           Foreground="#8FFFFFFF"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Border x:Name="EmptyGroupsPanel"
                                    CornerRadius="16"
                                    Background="#661A1B22"
                                    BorderBrush="#233B4654"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,6,12">
                                <TextBlock Text="No groups yet."
                                           Foreground="#A8FFFFFF"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Groups}"
                                          ItemTemplate="{StaticResource GroupTemplate}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="4"
                        Margin="18,12,18,16"
                        CornerRadius="14"
                        Background="#701A1B22"
                        BorderBrush="#263B4654"
                        BorderThickness="1"
                        Padding="12,9">
                    <TextBlock x:Name="StatusText"
                               Text="Ready."
                               Foreground="#A8FFFFFF"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
