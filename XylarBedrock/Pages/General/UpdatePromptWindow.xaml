<Window x:Class="XylarBedrock.Pages.General.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="330"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <CubicEase x:Key="UpdateEaseOut" EasingMode="EaseOut"/>

        <Style x:Key="UpdaterButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.035"
                                                         Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.035"
                                                         Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.16"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.76"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#8F000000">
        <Border x:Name="DialogCard"
                Width="484"
                Padding="26"
                CornerRadius="18"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="DialogScale" ScaleX="0.94" ScaleY="0.94"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="36"
                                  ShadowDepth="0"
                                  Color="#000000"
                                  Opacity="0.78"/>
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F31B1B1B" Offset="0"/>
                    <GradientStop Color="#F10E1118" Offset="0.48"/>
                    <GradientStop Color="#F3231C10" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="72"
                            Height="72"
                            CornerRadius="16"
                            Background="#B30B0B0B"
                            BorderBrush="#70FFD83D"
                            BorderThickness="1"
                            Padding="10"
                            HorizontalAlignment="Left">
                        <Image Source="/XylarBedrock;component/resources/images/icons/xylarbedrock.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="XylarBedrock update"
                                   Foreground="#FFFFD83D"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                                   FontSize="27"
                                   TextOptions.TextFormattingMode="Display"/>
                        <TextBlock x:Name="VersionText"
                                   Margin="0,6,0,0"
                                   Foreground="#DDEDEDED"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,24,0,0"
                           Text="do you want to update to the next version?"
                           Foreground="White"
                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="BodyText"
                           Grid.Row="2"
                           Margin="0,12,0,22"
                           Foreground="#CFCFCF"
                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                           FontSize="13"
                           LineHeight="19"
                           TextWrapping="Wrap"
                           MaxHeight="64"/>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="You can update later from About or the update button."
                               MaxWidth="205"
                               Margin="0,0,54,0"
                               Foreground="#8FFFFFFF"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               FontSize="11"
                               HorizontalAlignment="Left"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Later"
                            Style="{StaticResource UpdaterButton}"
                            Background="#3B3B3B"
                            BorderBrush="#686868"
                            Click="LaterButton_Click"/>

                    <Button Grid.Column="3"
                            Content="Update Now"
                            Style="{StaticResource UpdaterButton}"
                            Background="#2E8B42"
                            BorderBrush="#73D36F"
                            Click="UpdateNowButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
